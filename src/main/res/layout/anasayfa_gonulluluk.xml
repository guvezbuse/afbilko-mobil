<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/filterContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#B00020"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategoriye Göre Filtrele"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="4dp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFiltre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHepsi"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hepsi"
                    android:checked="true"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipGida"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🍞 Gıda"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSu"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 Su"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIlac"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💊 İlaç"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEnkaz"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🆘 ENKAZ"
                    android:textColor="@android:color/white"
                    app:chipBackgroundColor="#FF0000" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTahliye"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗 Tahliye"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBarinma"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛺ Barınma"
                    app:chipBackgroundColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDiger"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦 Diğer"
                    app:chipBackgroundColor="@android:color/white" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <fragment
        android:id="@+id/mapGonullu"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/filterContainer"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnGoogleMapsAc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="100dp"
        android:src="@android:drawable/ic_menu_directions"
        android:visibility="gone"
        app:backgroundTint="#FFFFFF"
        app:tint="#4285F4"
        app:elevation="8dp"
        app:fabSize="normal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnBuAlandaAra"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔍 Bu Alanda Ara (50km)"
        android:backgroundTint="#B00020"
        android:textColor="@android:color/white"
        android:layout_marginBottom="24dp"
        android:elevation="10dp"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>